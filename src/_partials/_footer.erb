<footer class="footer">
  <div class="container">
    <div class="columns">
      <div class="column is-5 is-offset-1">
        <a class="footer-logo" href="/" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <img
            src="/images/logotipo.png"
            alt="Logo Mãe Rainha"
            style="
              height: 150px;
              width: 150px;
              border-radius: 50%;
              object-fit: scale-down;
              object-position: center;
              border: 1px solid rgba(201,151,58,0.45);
              box-shadow: 0 0 24px rgba(201,151,58,0.3);"
          >
          <h1 class="f-titulo">
            Grupo de Oração
            <em class="destaque">Mãe Rainha</em>
          </h1>
        </a>
      </div>

      <div class="column is-2">
        <p class="footer-titulo">Navegação</p>
        <a class="footer-link" href="#sobre">Sobre Nós</a>
        <a class="footer-link" href="#encontros">Encontros</p>
        <a class="footer-link" href="#testemunhos">Testemunhos</p>
        <a class="footer-link" href="/liturgia">Liturgia Diária</p>
        <a class="footer-link" href="#participar">Pedido de Oração</p>
      </div>

      <div class="column is-3">
        <p class="footer-titulo">Contato</p>
        <a href="mailto:<%= site.data.grupo.contato.email %>" class="footer-link">
          <i class="fas fa-envelope" style="width:16px; color:rgba(201,151,58,0.6)"></i>
          &nbsp; <%= site.data.grupo.contato.email %>
        </a>
        <a href="tel:<%= site.data.grupo.contato.telefone %>" class="footer-link">
          <i class="fas fa-phone" style="width:16px; color:rgba(201,151,58,0.6)"></i>
          &nbsp; <%= site.data.grupo.contato.telefone %>
        </a>
        <a href="<%= site.data.grupo.contato.link_instagram %>" class="footer-link">
          <i class="fab fa-instagram" style="width:16px; color:rgba(201,151,58,0.6)"></i>
          &nbsp; <%= site.data.grupo.contato.instagram %>
        </a>
        <a href="<%= site.data.grupo.contato.maps_link %>" class="footer-link">
          <i class="fas fa-map-marker-alt" style="width:16px; color:rgba(201,151,58,0.6)"></i>
          &nbsp; <%= site.data.grupo.contato.endereco %>
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        © <%= Time.now.year %> Grupo de Oração Mãe Rainha · Todos os direitos reservados
      </p>
      <div class="footer-social">
        <a href="<%= site.data.grupo.contato.link_instagram %>" class="social-btn" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="<%= site.data.grupo.contato.facebook %>"class="social-btn" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="social-btn" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        <a href="#" class="social-btn" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
    </div>
  </div>
</footer>
